# Git ignore file for kienlt90 portal
# Viết bởi Antigravity

# Ignore Portable Node.js binaries
node-portable/

# Ignore Next.js build and node modules
**/node_modules/
**/.next/
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Ignore OS files
.DS_Store
Thumbs.db

# Python temporary files
__pycache__/
*.pyc

# Local Telegram Chat ID configuration
user_chat_id.json

# Scratch and test files
check_*.py
debug_*.py
dump_*.py
find_*.py
inspect_*.py
open_*.py
print_*.py
screenshot_*.py
test_*.py
debug_dom_output.txt
running_tasks.json
chrome_bot_profile/
